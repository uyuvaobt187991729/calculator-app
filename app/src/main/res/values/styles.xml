<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="CalcBtnBase" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">5dp</item>
        <item name="android:textSize">26sp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="cornerRadius">100dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="rippleColor">#44FFFFFF</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="CalcBtnNum" parent="CalcBtnBase">
        <item name="backgroundTint">#1C1C1E</item>
    </style>

    <style name="CalcBtnDark" parent="CalcBtnBase">
        <item name="backgroundTint">#2C2C2E</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">22sp</item>
    </style>

    <style name="CalcBtnOp" parent="CalcBtnBase">
        <item name="backgroundTint">#1C3A1C</item>
        <item name="android:textColor">#30D158</item>
        <item name="android:textSize">28sp</item>
    </style>

    <style name="CalcBtnEquals" parent="CalcBtnBase">
        <item name="backgroundTint">#30D158</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">28sp</item>
    </style>

    <style name="SciBtn" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_rowWeight">1</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#30D158</item>
        <item name="android:layout_margin">2dp</item>
        <item name="rippleColor">#4430D158</item>
    </style>

    <style name="BottomSheetStyle" parent="Theme.MaterialComponents.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BottomSheetModalStyle</item>
    </style>

    <style name="BottomSheetModalStyle" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="shapeAppearance">@style/SheetShape</item>
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="SheetShape" parent="ShapeAppearance.MaterialComponents">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
    </style>

</resources>
