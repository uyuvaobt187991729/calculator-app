<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1E1E1E"
    android:padding="12dp">

    <TextView
        android:id="@+id/display"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:text="0"
        android:textSize="48sp"
        android:textColor="#FFFFFF"
        android:gravity="end|bottom"
        android:padding="16dp"
        android:background="#2C2C2C"
        android:maxLines="2"
        android:ellipsize="start"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:layout_marginTop="8dp">
        <Button android:id="@+id/btnClear" style="@style/CalcBtn.Orange" android:text="C" android:layout_weight="1"/>
        <Button android:id="@+id/btnBack" style="@style/CalcBtn.Orange" android:text="⌫" android:layout_weight="1"/>
        <Button android:id="@+id/btnDiv" style="@style/CalcBtn.Orange" android:text="÷" android:layout_weight="1"/>
        <Button android:id="@+id/btnMul" style="@style/CalcBtn.Orange" android:text="×" android:layout_weight="1"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:layout_marginTop="8dp">
        <Button android:id="@+id/btn7" style="@style/CalcBtn" android:text="7" android:layout_weight="1"/>
        <Button android:id="@+id/btn8" style="@style/CalcBtn" android:text="8" android:layout_weight="1"/>
        <Button android:id="@+id/btn9" style="@style/CalcBtn" android:text="9" android:layout_weight="1"/>
        <Button android:id="@+id/btnSub" style="@style/CalcBtn.Orange" android:text="−" android:layout_weight="1"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:layout_marginTop="8dp">
        <Button android:id="@+id/btn4" style="@style/CalcBtn" android:text="4" android:layout_weight="1"/>
        <Button android:id="@+id/btn5" style="@style/CalcBtn" android:text="5" android:layout_weight="1"/>
        <Button android:id="@+id/btn6" style="@style/CalcBtn" android:text="6" android:layout_weight="1"/>
        <Button android:id="@+id/btnAdd" style="@style/CalcBtn.Orange" android:text="+" android:layout_weight="1"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:layout_marginTop="8dp">
        <Button android:id="@+id/btn1" style="@style/CalcBtn" android:text="1" android:layout_weight="1"/>
        <Button android:id="@+id/btn2" style="@style/CalcBtn" android:text="2" android:layout_weight="1"/>
        <Button android:id="@+id/btn3" style="@style/CalcBtn" android:text="3" android:layout_weight="1"/>
        <Button android:id="@+id/btnEquals" style="@style/CalcBtn.Green" android:text="=" android:layout_weight="1"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:layout_marginTop="8dp">
        <Button android:id="@+id/btn0" style="@style/CalcBtn" android:text="0" android:layout_weight="3"/>
        <Button android:id="@+id/btnDot" style="@style/CalcBtn" android:text="." android:layout_weight="1"/>
    </LinearLayout>

</LinearLayout>
