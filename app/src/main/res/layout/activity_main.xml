<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- Display area: fixed height, never moves -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="35"
        android:orientation="vertical"
        android:gravity="bottom"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tvExpression"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="18sp"
            android:textColor="#888888"
            android:gravity="end"
            android:maxLines="2"/>

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="64sp"
            android:textColor="#FFFFFF"
            android:gravity="end"
            android:maxLines="1"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="24sp"
            android:autoSizeMaxTextSize="64sp"/>

    </LinearLayout>

    <!-- Icon bar: fixed -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btnHistory"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_history"
            android:tint="#AAAAAA"
            android:contentDescription="History"/>

        <ImageButton
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_ruler"
            android:tint="#AAAAAA"
            android:contentDescription="Ruler"/>

        <ImageButton
            android:id="@+id/btnScientific"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_scientific"
            android:tint="#AAAAAA"
            android:contentDescription="Scientific"/>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_backspace"
            android:tint="#AAAAAA"
            android:contentDescription="Backspace"/>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#222222"/>

    <!-- Scientific panel (hidden by default, fixed height) -->
    <GridLayout
        android:id="@+id/scientificPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:columnCount="4"
        android:padding="4dp">

        <Button android:id="@+id/btnSin"       style="@style/SciBtn" android:text="sin"/>
        <Button android:id="@+id/btnCos"       style="@style/SciBtn" android:text="cos"/>
        <Button android:id="@+id/btnTan"       style="@style/SciBtn" android:text="tan"/>
        <Button android:id="@+id/btnSqrt"      style="@style/SciBtn" android:text="√"/>
        <Button android:id="@+id/btnSquare"    style="@style/SciBtn" android:text="x²"/>
        <Button android:id="@+id/btnLog"       style="@style/SciBtn" android:text="log"/>
        <Button android:id="@+id/btnLn"        style="@style/SciBtn" android:text="ln"/>
        <Button android:id="@+id/btnPow"       style="@style/SciBtn" android:text="xⁿ"/>
        <Button android:id="@+id/btnPi"        style="@style/SciBtn" android:text="π"/>
        <Button android:id="@+id/btnE"         style="@style/SciBtn" android:text="e"/>
        <Button android:id="@+id/btnInverse"   style="@style/SciBtn" android:text="1/x"/>
        <Button android:id="@+id/btnFactorial" style="@style/SciBtn" android:text="n!"/>
    </GridLayout>

    <!-- Button grid: takes remaining space, buttons NEVER move -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="65"
        android:orientation="vertical"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <Button android:id="@+id/btnClear"   style="@style/CalcBtnDark"   android:text="C" android:textColor="#FF453A"/>
            <Button android:id="@+id/btnParens"  style="@style/CalcBtnDark"   android:text="( )"/>
            <Button android:id="@+id/btnPercent" style="@style/CalcBtnDark"   android:text="%"/>
            <Button android:id="@+id/btnDiv"     style="@style/CalcBtnOp"     android:text="÷"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <Button android:id="@+id/btn7"   style="@style/CalcBtnNum" android:text="7"/>
            <Button android:id="@+id/btn8"   style="@style/CalcBtnNum" android:text="8"/>
            <Button android:id="@+id/btn9"   style="@style/CalcBtnNum" android:text="9"/>
            <Button android:id="@+id/btnMul" style="@style/CalcBtnOp"  android:text="×"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <Button android:id="@+id/btn4"   style="@style/CalcBtnNum" android:text="4"/>
            <Button android:id="@+id/btn5"   style="@style/CalcBtnNum" android:text="5"/>
            <Button android:id="@+id/btn6"   style="@style/CalcBtnNum" android:text="6"/>
            <Button android:id="@+id/btnSub" style="@style/CalcBtnOp"  android:text="−"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <Button android:id="@+id/btn1"   style="@style/CalcBtnNum" android:text="1"/>
            <Button android:id="@+id/btn2"   style="@style/CalcBtnNum" android:text="2"/>
            <Button android:id="@+id/btn3"   style="@style/CalcBtnNum" android:text="3"/>
            <Button android:id="@+id/btnAdd" style="@style/CalcBtnOp"  android:text="+"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <Button android:id="@+id/btnPlusMinus" style="@style/CalcBtnNum"    android:text="+/−"/>
            <Button android:id="@+id/btn0"         style="@style/CalcBtnNum"    android:text="0"/>
            <Button android:id="@+id/btnDot"       style="@style/CalcBtnNum"    android:text="."/>
            <Button android:id="@+id/btnEquals"    style="@style/CalcBtnEquals" android:text="="/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
